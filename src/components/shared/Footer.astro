---
const year = new Date().getFullYear();
---

<footer class="mt-auto py-16" style="border-top: 0.5px solid #323028;">
  <div class="mx-auto max-w-7xl px-6 sm:px-10">

    <div class="mb-14 grid grid-cols-1 gap-12 sm:grid-cols-2 lg:grid-cols-4">

      <!-- Brand -->
      <div class="lg:col-span-1">
        <div class="mb-6">
          <img
            src="/OnlyNerds.svg"
            alt="OnlyNerds"
            class="h-52 w-auto transition-opacity duration-300 hover:opacity-100"
            style="opacity: 0.9;"
            onerror="this.onerror=null;this.src='/OnlyNerds.png'"
          />
        </div>
        <p class="font-mono text-xs leading-relaxed text-slate-400 transition-colors hover:text-slate-200">
          Career intelligence for people who do their homework.
          Free, community-built, no sign-ups.
        </p>
      </div>

      <!-- Navigation -->
      <div>
        <p class="mb-5 font-mono text-[10px] font-semibold uppercase tracking-[0.22em] text-slate-400">Pages</p>
        <div class="flex flex-col gap-3">
          {[
            { href: '/companies',  label: 'Companies'    },
            { href: '/job-search', label: 'Job Search'   },
            { href: '/resources',  label: 'Resources'    },
            { href: '/contact',    label: 'Contact'      },
            { href: '/brand',      label: 'Brand Assets' },
          ].map((l) => (
            <a
              href={l.href}
              class="group flex items-center gap-2 font-mono text-xs uppercase tracking-[0.12em] text-slate-400 transition-colors duration-200 hover:text-slate-100"
            >
              <span class="inline-block h-px w-0 bg-slate-400 transition-all duration-300 group-hover:w-4"></span>
              {l.label}
            </a>
          ))}
        </div>
      </div>

      <!-- Creator -->
      <div>
        <p class="mb-5 font-mono text-[10px] font-semibold uppercase tracking-[0.22em] text-slate-400">Creator</p>
        <p class="mb-0.5 font-sans text-sm font-semibold text-slate-100 transition-colors hover:text-white">Pavan Yellathakota</p>
        <p class="mb-5 font-mono text-xs text-slate-400">Data Scientist &amp; ML Practitioner</p>
        <div class="flex flex-wrap gap-2">
          {[
            { href: 'https://pye.pages.dev',                  label: 'pye.pages.dev',    external: true  },
            { href: 'https://github.com/yellatp',             label: 'GitHub',           external: true  },
            { href: 'https://linkedin.com/in/yellatp',        label: 'LinkedIn',         external: true  },
            { href: 'mailto:pavan.yellathakota.ds@gmail.com', label: 'Email',            external: false },
          ].map((l) => (
            <a
              href={l.href}
              target={l.external ? '_blank' : undefined}
              rel={l.external ? 'noopener noreferrer' : undefined}
              class="font-mono text-[10px] uppercase tracking-[0.1em] text-slate-400 transition-colors duration-200 hover:text-slate-100 px-2.5 py-1.5"
              style="border: 0.5px solid #323028;"
              onmouseover="this.style.borderColor='#706E66'"
              onmouseout="this.style.borderColor='#323028'"
            >
              {l.label}
            </a>
          ))}
        </div>
      </div>

      <!-- Built With -->
      <div>
        <p class="mb-5 font-mono text-[10px] font-semibold uppercase tracking-[0.22em] text-slate-400">Built With</p>
        <a
          href="https://alphonsohq.com/"
          target="_blank"
          rel="noopener noreferrer"
          class="group inline-flex items-center gap-2.5 px-3 py-2.5 transition-all duration-300 hover:bg-slate-800"
          style="border: 0.5px solid #323028;"
          onmouseover="this.style.borderColor='#706E66'"
          onmouseout="this.style.borderColor='#323028'"
        >
          <img src="/Alphonso_logo.png" alt="Alphonso AI" class="h-6 w-6 object-contain" />
          <span class="flex items-baseline gap-0">
            <span class="px-1.5 py-0.5 text-sm font-bold leading-none" style="background:#ffffff;color:#111111;">Alphonso</span>
            <span class="px-1.5 py-0.5 text-sm font-bold leading-none" style="background:#16a34a;color:#ffffff;">AI</span>
          </span>
        </a>
        <p class="mt-3 font-mono text-[10px] uppercase tracking-[0.1em] text-slate-400">
          Co-founded by Pavan Yellathakota
        </p>
      </div>

    </div>

    <!-- Bottom bar -->
    <div
      class="flex flex-col gap-2 pt-6 sm:flex-row sm:items-center sm:justify-between"
      style="border-top: 0.5px solid #323028;"
    >
      <p class="font-mono text-[10px] uppercase tracking-[0.1em] text-slate-400 transition-colors hover:text-slate-200">
        &copy; {year} OnlyNerds. Data from public records.
      </p>
      <p class="font-mono text-[10px] uppercase tracking-[0.1em] text-slate-400">
        Licensed under
        <a href="/LICENSE" class="text-slate-300 underline transition-colors hover:text-slate-100 ml-1">Apache 2.0</a>
      </p>
    </div>

  </div>
</footer>
