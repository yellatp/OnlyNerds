---
const links = [
  { href: '/',          label: 'Home',           dot: '' },
  { href: '/companies', label: 'Companies',       dot: 'bg-emerald-400' },
  { href: '/job-search',label: 'Job Search',      dot: 'bg-amber-400' },
  { href: '/resources', label: 'Resources',       dot: 'bg-blue-400' },
  { href: '/contact',   label: 'Contact',         dot: '' },
];

const path = Astro.url.pathname;

function isActive(href: string): boolean {
  if (href === '/') return path === '/';
  return path.startsWith(href);
}
---

<header class="sticky top-0 z-40 border-b border-slate-800 bg-[#080810]">
  <div class="mx-auto flex h-14 max-w-7xl items-center justify-between px-4 sm:px-6">

    <!-- Logo -->
    <a href="/" class="flex items-center">
      <img src="/OnlyNerds_Nav.svg" alt="OnlyNerds" class="h-11 w-auto" onerror="this.onerror=null;this.src='/OnlyNerds_Nav.png'" />
    </a>

    <!-- Desktop links -->
    <nav class="hidden items-center gap-1 md:flex">
      {links.map((l) => (
        <a
          href={l.href}
          class:list={[
            'flex items-center gap-1.5 rounded-lg px-3 py-2 text-sm font-medium transition-colors',
            isActive(l.href)
              ? 'bg-slate-800 text-white'
              : 'text-slate-400 hover:bg-slate-900 hover:text-white',
          ]}
        >
          {l.dot && <span class:list={['h-1.5 w-1.5 rounded-full', l.dot]} />}
          {l.label}
        </a>
      ))}
    </nav>

    <!-- Mobile toggle -->
    <button
      id="nav-toggle"
      type="button"
      aria-label="Toggle navigation"
      class="flex h-9 w-9 items-center justify-center rounded-lg text-slate-400 hover:bg-slate-800 hover:text-white transition-colors md:hidden"
    >
      <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" d="M4 6h16M4 12h16M4 18h16"/>
      </svg>
    </button>
  </div>

  <!-- Mobile drawer -->
  <div id="nav-drawer" class="hidden border-t border-slate-800 px-4 pb-4 pt-2 md:hidden">
    {links.map((l) => (
      <a
        href={l.href}
        class="flex items-center gap-2 rounded-lg px-3 py-2.5 text-sm text-slate-400 hover:bg-slate-900 hover:text-white transition-colors"
      >
        {l.dot && <span class:list={['h-1.5 w-1.5 rounded-full', l.dot]} />}
        {l.label}
      </a>
    ))}
  </div>
</header>

<script>
  const toggle = document.getElementById('nav-toggle');
  const drawer = document.getElementById('nav-drawer');
  toggle?.addEventListener('click', () => drawer?.classList.toggle('hidden'));
</script>
