---
export const prerender = true;
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/shared/Navbar.astro';
import Footer from '../components/shared/Footer.astro';

const assets = [
  {
    name: 'OnlyNerds (Primary)',
    description: 'Main logo for general use, footer, and print.',
    bg: '#141410',
    files: [
      { label: 'SVG', href: '/OnlyNerds.svg', download: 'OnlyNerds.svg' },
      { label: 'PNG', href: '/OnlyNerds.png', download: 'OnlyNerds.png' },
    ],
    preview: '/OnlyNerds.svg',
    previewFallback: '/OnlyNerds.png',
  },
  {
    name: 'OnlyNerds Nav',
    description: 'Compact logo optimized for navigation bars and tight spaces.',
    bg: '#0D0D0D',
    files: [
      { label: 'SVG', href: '/OnlyNerds_Nav.svg', download: 'OnlyNerds_Nav.svg' },
      { label: 'PNG', href: '/OnlyNerds_Nav.png', download: 'OnlyNerds_Nav.png' },
    ],
    preview: '/OnlyNerds_Nav.svg',
    previewFallback: '/OnlyNerds_Nav.png',
  },
];
---

<Layout
  title="Brand Assets - Logo Downloads"
  description="Download OnlyNerds logo assets in SVG and PNG formats. Free to use with attribution for blog posts, presentations, and contributions."
  keywords="OnlyNerds logo download, OnlyNerds SVG PNG, OnlyNerds brand assets"
>
  <div class="flex min-h-screen flex-col">
    <Navbar />

    <main class="flex-1 mx-auto w-full max-w-7xl px-6 sm:px-10" style="padding-top: 80px; padding-bottom: 80px;">

      <div class="mb-12">
        <p class="mb-4 font-mono text-[10px] uppercase tracking-[0.22em] text-slate-500">// Brand Assets</p>
        <h1 class="mb-4 font-display font-black text-slate-100" style="font-size:clamp(2.2rem,6vw,3.5rem); line-height:0.95; letter-spacing:-0.025em;">
          Logo Downloads
        </h1>
        <p class="max-w-lg font-mono text-xs leading-relaxed text-slate-400">
          Download the OnlyNerds logos for use in blog posts, presentations, or community contributions.
          Free to use with attribution.
        </p>
      </div>

      <!-- Usage guidelines -->
      <div class="mb-12 p-6" style="border: 0.5px solid #1C1C18; background: #141410;">
        <p class="mb-4 font-mono text-[10px] uppercase tracking-[0.2em] text-slate-500">// Usage Guidelines</p>
        <ul class="flex flex-col gap-3">
          {[
            'Do not alter the logo colors or proportions.',
            'Use the Nav variant in toolbars and compact layouts.',
            'Always link back to onlynerds.win when featuring the logo publicly.',
            'SVG is preferred for web and digital use; PNG for presentations and documents.',
          ].map((item) => (
            <li class="flex items-start gap-3 font-mono text-xs text-slate-400 transition-colors hover:text-slate-200">
              <span class="mt-0.5 shrink-0 font-mono text-slate-600">--</span>
              {item}
            </li>
          ))}
        </ul>
      </div>

      <!-- Asset cards — full-width tall previews -->
      <div class="grid grid-cols-1 gap-px bg-slate-800 lg:grid-cols-2">
        {assets.map((a) => (
          <div style="background: #0D0D0D;">
            <!-- Large preview area -->
            <div
              class="flex items-center justify-center"
              style={`background: ${a.bg}; border-bottom: 0.5px solid #1C1C18; min-height: 480px; padding: 48px;`}
            >
              <img
                src={a.preview}
                alt={a.name}
                style="max-height: 320px; max-width: 100%; width: auto; height: auto; object-fit: contain;"
                onerror={`this.onerror=null;this.src='${a.previewFallback}'`}
              />
            </div>

            <!-- Info + downloads -->
            <div class="p-8">
              <p class="mb-1 font-sans text-base font-semibold text-slate-100 transition-colors hover:text-white">
                {a.name}
              </p>
              <p class="mb-6 font-mono text-xs text-slate-400">{a.description}</p>
              <div class="flex flex-wrap gap-3">
                {a.files.map((f) => (
                  <a
                    href={f.href}
                    download={f.download}
                    class="group inline-flex items-center gap-2 px-5 py-2.5 font-mono text-[10px] uppercase tracking-[0.14em] text-slate-300 transition-all duration-200 hover:bg-slate-100 hover:text-slate-900"
                    style="border: 0.5px solid #323028;"
                    onmouseover="this.style.borderColor='transparent'"
                    onmouseout="this.style.borderColor='#323028'"
                  >
                    <svg class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                      <path d="M12 3v13M5 15l7 7 7-7" stroke-linecap="round" stroke-linejoin="round"/>
                      <path d="M3 21h18" stroke-linecap="round"/>
                    </svg>
                    Download {f.label}
                  </a>
                ))}
              </div>
            </div>
          </div>
        ))}
      </div>

      <!-- Attribution -->
      <div class="mt-10 p-6" style="border: 0.5px solid #1C1C18; background: #141410;">
        <p class="font-mono text-xs text-slate-400">
          OnlyNerds is free and community-built.
          Built by <a href="https://pye.pages.dev" target="_blank" rel="noopener noreferrer" class="text-slate-200 underline transition-colors hover:text-white">PYE</a> in association with
          <a href="https://alphonso.app" target="_blank" rel="noopener noreferrer" class="text-slate-200 underline transition-colors hover:text-white">Alphonso AI</a>.
          Star us on <a href="https://github.com/yellatp/OnlyNerds" target="_blank" rel="noopener noreferrer" class="text-slate-200 underline transition-colors hover:text-white">GitHub</a>.
        </p>
      </div>

    </main>

    <Footer />
  </div>
</Layout>
