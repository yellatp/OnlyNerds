---
export const prerender = true;
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/shared/Navbar.astro';
import Footer from '../components/shared/Footer.astro';

const assets = [
  {
    name: 'OnlyNerds (Primary)',
    description: 'Main logo for general use, footer, and print.',
    bg: 'bg-slate-900',
    files: [
      { label: 'SVG', href: '/OnlyNerds.svg', download: 'OnlyNerds.svg' },
      { label: 'PNG', href: '/OnlyNerds.png', download: 'OnlyNerds.png' },
    ],
    preview: '/OnlyNerds.svg',
    previewFallback: '/OnlyNerds.png',
  },
  {
    name: 'OnlyNerds Nav',
    description: 'Compact logo optimized for navigation bars and tight spaces.',
    bg: 'bg-[#080810]',
    files: [
      { label: 'SVG', href: '/OnlyNerds_Nav.svg', download: 'OnlyNerds_Nav.svg' },
      { label: 'PNG', href: '/OnlyNerds_Nav.png', download: 'OnlyNerds_Nav.png' },
    ],
    preview: '/OnlyNerds_Nav.svg',
    previewFallback: '/OnlyNerds_Nav.png',
  },
];
---

<Layout title="Brand Assets - OnlyNerds">
  <div class="flex min-h-screen flex-col">
    <Navbar />

    <main class="flex-1 mx-auto w-full max-w-7xl px-4 sm:px-6 py-10">

      <div class="mb-8">
        <div class="mb-3 flex items-center gap-2">
          <span class="h-2 w-2 rounded-full bg-violet-400"></span>
          <span class="text-xs font-semibold uppercase tracking-widest text-violet-500">Open Source Assets</span>
        </div>
        <h1 class="mb-3 text-3xl font-bold tracking-tight text-white sm:text-4xl">Brand Assets</h1>
        <p class="max-w-xl text-sm text-slate-400 leading-relaxed">
          Download the OnlyNerds logos for use in blog posts, presentations, or open-source contributions.
          All assets are free to use with attribution.
        </p>
      </div>

      <!-- Usage guidelines -->
      <div class="mb-8 rounded-xl border border-slate-800 bg-slate-900 px-5 py-4">
        <p class="mb-2 text-xs font-semibold uppercase tracking-widest text-slate-500">Usage Guidelines</p>
        <ul class="flex flex-col gap-1.5 text-sm text-slate-400">
          <li class="flex items-start gap-2"><span class="mt-0.5 h-1.5 w-1.5 shrink-0 rounded-full bg-violet-400"></span>Do not alter the logo colors or proportions.</li>
          <li class="flex items-start gap-2"><span class="mt-0.5 h-1.5 w-1.5 shrink-0 rounded-full bg-violet-400"></span>Use the Nav variant in toolbars and compact layouts.</li>
          <li class="flex items-start gap-2"><span class="mt-0.5 h-1.5 w-1.5 shrink-0 rounded-full bg-violet-400"></span>Always link back to <span class="text-violet-400">onlynerds.win</span> when featuring the logo publicly.</li>
          <li class="flex items-start gap-2"><span class="mt-0.5 h-1.5 w-1.5 shrink-0 rounded-full bg-violet-400"></span>SVG is preferred for web and digital use; PNG for presentations and documents.</li>
        </ul>
      </div>

      <!-- Asset cards -->
      <div class="grid grid-cols-1 gap-6 sm:grid-cols-2">
        {assets.map((a) => (
          <div class="overflow-hidden rounded-xl border border-slate-800 bg-slate-900">
            <!-- Preview area -->
            <div class:list={['flex h-44 items-center justify-center border-b border-slate-800', a.bg]}>
              <img
                src={a.preview}
                alt={a.name}
                class="h-16 w-auto"
                onerror={`this.onerror=null;this.src='${a.previewFallback}'`}
              />
            </div>

            <!-- Info + download -->
            <div class="px-5 py-4">
              <p class="mb-1 text-sm font-semibold text-white">{a.name}</p>
              <p class="mb-4 text-xs text-slate-500">{a.description}</p>
              <div class="flex flex-wrap gap-2">
                {a.files.map((f) => (
                  <a
                    href={f.href}
                    download={f.download}
                    class="inline-flex items-center gap-1.5 rounded-lg border border-slate-700 bg-slate-800 px-3 py-1.5 text-xs font-medium text-slate-300 transition-colors hover:border-violet-700 hover:bg-violet-950 hover:text-violet-300"
                  >
                    <svg class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                      <path d="M12 3v13M5 15l7 7 7-7" stroke-linecap="round" stroke-linejoin="round"/>
                      <path d="M3 21h18" stroke-linecap="round"/>
                    </svg>
                    Download {f.label}
                  </a>
                ))}
              </div>
            </div>
          </div>
        ))}
      </div>

      <!-- Attribution note -->
      <div class="mt-10 rounded-xl border border-violet-900 bg-violet-950/30 px-5 py-4">
        <p class="text-sm text-violet-300">
          OnlyNerds is open source and free forever.
          Built by <a href="https://pye.pages.dev" target="_blank" rel="noopener noreferrer" class="underline hover:text-violet-100">PYE</a> in association with
          <a href="https://alphonsohq.com" target="_blank" rel="noopener noreferrer" class="underline hover:text-violet-100">Alphonso AI</a>.
          Star us on <a href="https://github.com/yellatp" target="_blank" rel="noopener noreferrer" class="underline hover:text-violet-100">GitHub</a>.
        </p>
      </div>

    </main>

    <Footer />
  </div>
</Layout>
