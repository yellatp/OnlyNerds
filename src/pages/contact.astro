---
export const prerender = true;
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/shared/Navbar.astro';
import Footer from '../components/shared/Footer.astro';
---

<Layout
  title="Contact & Contribute - OnlyNerds"
  description="Contribute to OnlyNerds - the free career platform for tech jobseekers. Add company data, fix URLs, improve the UI, or share resources. Built by PYE in association with Alphonso AI."
  keywords="OnlyNerds contribute, career platform contributions, contribute job data, free career tool, PYE developer, Alphonso AI"
>
  <div class="flex min-h-screen flex-col">
    <Navbar />

    <main class="flex-1 mx-auto w-full max-w-4xl px-6 sm:px-10" style="padding-top: 80px; padding-bottom: 80px;">

      <!-- Header -->
      <div class="mb-12">
        <p class="mb-4 font-mono text-[10px] uppercase tracking-[0.22em] text-slate-500">// Contact &amp; Contribute</p>
        <h1 class="mb-4 font-display font-black text-slate-100" style="font-size:clamp(2.2rem,6vw,3.5rem); line-height:0.95; letter-spacing:-0.025em;">
          Get in Touch
        </h1>
        <p class="max-w-lg font-mono text-xs leading-relaxed text-slate-400">
          OnlyNerds is a community-built platform. Share resources, suggest improvements,
          or join as a contributor. Every contribution gets credited by name.
        </p>
      </div>

      <!-- Mission statement -->
      <div class="mb-10 p-6" style="border: 0.5px solid #1C1C18; background: #141410;">
        <p class="mb-4 font-display text-xl font-semibold italic leading-snug text-slate-200">
          "I water you, you water me. We grow together."
        </p>
        <p class="font-mono text-xs leading-relaxed text-slate-400">
          This platform exists because great resources are too scattered and too gatekept.
          OnlyNerds gives every jobseeker, student, and self-taught builder access to the same
          playbooks experienced practitioners use. Not a product. Not a business. A shared dictionary
          of strategies, tools, and paths, maintained by people who actually use them.
        </p>
      </div>

      <!-- Creator cards -->
      <div class="mb-10 grid grid-cols-1 gap-px bg-slate-800 sm:grid-cols-2">

        <!-- Creator -->
        <div class="bg-slate-900 p-6" style="border: 0.5px solid #1C1C18;">
          <div class="mb-4 flex items-center gap-3">
            <div
              class="flex h-10 w-10 shrink-0 items-center justify-center font-mono text-xs font-bold text-slate-300"
              style="border: 0.5px solid #323028; background: #1C1C18;"
            >
              PY
            </div>
            <div>
              <p class="font-sans text-sm font-semibold text-slate-100">Pavan Yellathakota</p>
              <p class="font-mono text-[10px] uppercase tracking-[0.12em] text-slate-500">Creator</p>
            </div>
          </div>
          <p class="mb-4 font-mono text-xs leading-relaxed text-slate-400">
            Data Scientist &amp; ML Practitioner. Co-Founder at Alphonso AI.
            Building tools that give every nerd an unfair advantage.
          </p>
          <div class="flex flex-wrap gap-2">
            {[
              { href: 'https://pye.pages.dev',                  label: 'pye.pages.dev', external: true  },
              { href: 'https://alphonsohq.com',                  label: 'alphonsohq.com', external: true },
              { href: 'https://github.com/yellatp',             label: 'github/yellatp', external: true },
              { href: 'https://linkedin.com/in/yellatp',        label: 'linkedin/yellatp', external: true },
            ].map((l) => (
              <a
                href={l.href}
                target={l.external ? '_blank' : undefined}
                rel={l.external ? 'noopener noreferrer' : undefined}
                class="font-mono text-[10px] uppercase tracking-[0.1em] text-slate-500 transition-colors hover:text-slate-300 px-2.5 py-1.5"
                style="border: 0.5px solid #1C1C18; background: #0D0D0D;"
              >
                {l.label}
              </a>
            ))}
          </div>
        </div>

        <!-- Email -->
        <div class="bg-slate-900 p-6" style="border: 0.5px solid #1C1C18;">
          <p class="mb-2 font-sans text-sm font-semibold text-slate-100">Get in Touch</p>
          <p class="mb-5 font-mono text-xs leading-relaxed text-slate-400">
            Have a resource to share? Found something that should be here? Want to improve the data or UI?
            Reach out directly. Responses are personal, not automated.
          </p>
          <a
            href="mailto:pavan.yellathakota.ds@gmail.com"
            class="inline-flex items-center gap-2 bg-slate-100 px-4 py-2.5 font-mono text-[10px] uppercase tracking-[0.14em] text-slate-900 transition-colors hover:bg-white"
          >
            <svg class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
            </svg>
            pavan.yellathakota.ds@gmail.com
          </a>
        </div>

      </div>

      <!-- How to contribute -->
      <div class="mb-10 p-6" style="border: 0.5px solid #1C1C18; background: #141410;">
        <p class="mb-6 font-mono text-[10px] uppercase tracking-[0.2em] text-slate-500">// How to Contribute</p>
        <div class="grid grid-cols-1 gap-px bg-slate-800 sm:grid-cols-2 lg:grid-cols-3">
          {[
            {
              idx: '01',
              title: 'Share a Resource',
              body: 'Email a link with a short description. It will go up with your name as contributor.',
            },
            {
              idx: '02',
              title: 'Add Company Data',
              body: 'Know a company missing from the H1B or Private Markets listings? Send the details and we verify and add it.',
            },
            {
              idx: '03',
              title: 'Improve the UI',
              body: 'Fork the repository on GitHub, make your changes, and open a pull request.',
            },
            {
              idx: '04',
              title: 'Fix Data Errors',
              body: 'Spotted a wrong career URL, a missing job board, or outdated information? Report it.',
            },
            {
              idx: '05',
              title: 'Write Strategy Content',
              body: 'Have a career strategy that worked? Write it up and share it. Context and credit included.',
            },
            {
              idx: '06',
              title: 'Spread the Word',
              body: 'Share OnlyNerds with one person who would benefit. The platform grows by word of mouth only.',
            },
          ].map((item) => (
            <div class="bg-slate-900 p-5">
              <p class="mb-3 font-mono text-[10px] uppercase tracking-[0.2em] text-slate-600">{item.idx}</p>
              <p class="mb-2 font-sans text-sm font-semibold text-slate-100">{item.title}</p>
              <p class="font-mono text-xs leading-relaxed text-slate-400">{item.body}</p>
            </div>
          ))}
        </div>
      </div>

      <!-- GitHub CTA -->
      <div class="p-6 text-center" style="border: 0.5px solid #1C1C18; background: #141410;">
        <p class="mb-1 font-sans text-sm font-semibold text-slate-100">Fork it. Improve it. Open a PR.</p>
        <p class="mb-6 font-mono text-xs text-slate-400">Everything you contribute is credited.</p>
        <a
          href="https://github.com/yellatp/OnlyNerds"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 bg-slate-100 px-5 py-2.5 font-mono text-[10px] uppercase tracking-[0.14em] text-slate-900 transition-colors hover:bg-white"
        >
          <svg class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="currentColor">
            <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"/>
          </svg>
          View on GitHub
        </a>
      </div>

    </main>

    <Footer />
  </div>
</Layout>
