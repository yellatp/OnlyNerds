---
export const prerender = true;
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/shared/Navbar.astro';
import Footer from '../components/shared/Footer.astro';
import PrivateFilter from '../components/private/PrivateFilter';
import { getPrivateCompanies, getPrivateSectors, getPrivateRounds } from '../data/privateMarkets';

const companies = getPrivateCompanies();
const sectors   = getPrivateSectors();
const rounds    = getPrivateRounds();

const topSectors = sectors.slice(0, 4).map((s) => ({
  name: s,
  count: companies.filter((c) => c.sector === s).length,
}));
---

<Layout
  title="Private Market Companies - Late Stage Startups Hiring"
  description="Explore late-stage private companies across tech, fintech, healthtech, and AI that are actively hiring. Filter by sector, funding round, and amount raised. Pre-IPO and Series B/C/D companies."
  keywords="private market companies hiring, late stage startup jobs, Series B C D companies, pre-IPO companies jobs, private tech companies, fintech startups hiring, healthtech companies jobs, AI startups hiring 2025, unicorn companies jobs"
>
  <div class="flex min-h-screen flex-col">
    <Navbar />

    <main class="flex-1 mx-auto w-full max-w-7xl px-4 sm:px-6 py-10">

      <div class="mb-8">
        <div class="mb-3 flex items-center gap-2">
          <span class="h-2 w-2 rounded-full bg-amber-400"></span>
          <span class="text-xs font-semibold uppercase tracking-widest text-amber-500">Institutional Data</span>
        </div>
        <h1 class="mb-3 text-3xl font-bold tracking-tight text-white sm:text-4xl">
          Private Markets
        </h1>
        <p class="max-w-xl text-sm text-slate-400 leading-relaxed">
          {companies.length.toLocaleString()} privately listed companies sourced from institutional research.
          Filter by sector and funding stage to surface pre-IPO opportunities.
        </p>

        <div class="mt-5 flex flex-wrap gap-3">
          {topSectors.map((s) => (
            <div class="rounded-xl border border-slate-800 bg-slate-900 px-4 py-3">
              <p class="text-xl font-bold text-amber-400">{s.count.toLocaleString()}</p>
              <p class="text-xs text-slate-500">{s.name}</p>
            </div>
          ))}
          <div class="rounded-xl border border-slate-800 bg-slate-900 px-4 py-3">
            <p class="text-xl font-bold text-white">{companies.length.toLocaleString()}</p>
            <p class="text-xs text-slate-500">Total companies</p>
          </div>
        </div>
      </div>

      <div class="mb-5 flex items-start gap-2.5 rounded-lg border border-slate-800 bg-slate-900 px-4 py-3">
        <svg class="mt-0.5 h-4 w-4 shrink-0 text-amber-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/>
        </svg>
        <p class="text-xs text-slate-400">
          <span class="font-semibold text-white">Institutional Data</span> - sourced from private market research databases.
          Career links use Smart Career Routing.
        </p>
      </div>

      <PrivateFilter client:load companies={companies} sectors={sectors} rounds={rounds} />
    </main>

    <Footer />
  </div>

</Layout>
