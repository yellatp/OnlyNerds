<style>
  .modal-panel.is-open {
    display: flex;
  }
</style>

<script>
  /* Modal open/close system */
  const backdrop = document.getElementById('modal-backdrop')!;
  const modals   = document.querySelectorAll<HTMLDivElement>('[data-modal]');

  function openModal(id: string) {
    const modal = document.getElementById(`modal-${id}`);
    if (!modal) return;
    modal.classList.add('is-open');
    backdrop.classList.remove('hidden');
    document.body.style.overflow = 'hidden';
  }

  function closeAll() {
    modals.forEach((m) => m.classList.remove('is-open'));
    backdrop.classList.add('hidden');
    document.body.style.overflow = '';
  }

  /* Open buttons on cards */
  document.querySelectorAll<HTMLButtonElement>('[data-open]').forEach((btn) => {
    btn.addEventListener('click', () => openModal(btn.getAttribute('data-open') ?? ''));
  });

  /* Close buttons inside modals */
  document.querySelectorAll<HTMLButtonElement>('[data-close]').forEach((btn) => {
    btn.addEventListener('click', closeAll);
  });

  /* Close on backdrop click */
  backdrop.addEventListener('click', closeAll);

  /* Close on Escape key */
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeAll();
  });

  /* Copy-to-clipboard for dork query blocks */
  document.querySelectorAll<HTMLButtonElement>('[data-copy-btn]').forEach((btn) => {
    btn.addEventListener('click', (e) => {
      e.stopPropagation();
      const targetId = btn.getAttribute('data-copy-btn');
      const pre = document.getElementById(targetId ?? '');
      if (!pre) return;
      navigator.clipboard.writeText(pre.textContent?.trim() ?? '').then(() => {
        const orig = btn.textContent;
        btn.textContent = 'Copied!';
        btn.classList.add('text-emerald-400');
        setTimeout(() => {
          btn.textContent = orig;
          btn.classList.remove('text-emerald-400');
        }, 2000);
      });
    });
  });
</script>
