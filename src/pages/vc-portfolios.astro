---
export const prerender = true;
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/shared/Navbar.astro';
import Footer from '../components/shared/Footer.astro';
import VCDirectory from '../components/vc/VCDirectory';
import { getVCFirms, getVCFirmsByType } from '../data/vcPortfolios';

const firms  = getVCFirms();
const vcs    = getVCFirmsByType('VC');
const accels = getVCFirmsByType('accelerator');
const withJob = firms.filter((f) => f.hasJobBoard).length;
---

<Layout title="VC Portfolios">
  <div class="flex min-h-screen flex-col">
    <Navbar />

    <main class="flex-1 mx-auto w-full max-w-7xl px-4 sm:px-6 py-10">

      <div class="mb-8">
        <div class="mb-3 flex items-center gap-2">
          <span class="h-2 w-2 rounded-full bg-violet-400"></span>
          <span class="text-xs font-semibold uppercase tracking-widest text-violet-500">VC Jobboards (VC Backed)</span>
        </div>
        <h1 class="mb-3 text-3xl font-bold tracking-tight text-white sm:text-4xl">
          VC Portfolios
        </h1>
        <p class="max-w-xl text-sm text-slate-400 leading-relaxed">
          Top venture capital firms and accelerators with direct links to their portfolio job boards.
          Funded startups hire fast. Go straight to the source.
        </p>

        <div class="mt-5 flex flex-wrap gap-3">
          {[
            { label: 'VC Firms',          value: vcs.length,    color: 'text-violet-400' },
            { label: 'Accelerators',      value: accels.length, color: 'text-blue-400' },
            { label: 'Direct Job Boards', value: withJob,       color: 'text-emerald-400' },
          ].map((s) => (
            <div class="rounded-xl border border-slate-800 bg-slate-900 px-4 py-3">
              <p class:list={['text-xl font-bold', s.color]}>{s.value}</p>
              <p class="text-xs text-slate-500">{s.label}</p>
            </div>
          ))}
        </div>
      </div>

      <!-- Featured -->
      <div class="mb-8 grid grid-cols-1 gap-3 sm:grid-cols-2">
        {[
          { href: 'https://www.ycombinator.com/jobs', initials: 'YC', name: 'Y Combinator Job Board',    sub: '5,800+ portfolio companies', badgeClass: 'bg-orange-950 text-orange-400 border border-orange-900', hoverClass: 'hover:border-orange-800' },
          { href: 'https://jobs.techstars.com/companies', initials: 'TS', name: 'Techstars Job Board', sub: 'Global accelerator alumni',    badgeClass: 'bg-blue-950 text-blue-400 border border-blue-900',     hoverClass: 'hover:border-blue-800' },
        ].map((f) => (
          <a
            href={f.href}
            target="_blank"
            rel="noopener noreferrer"
            class:list={[
              'group flex items-center gap-4 rounded-xl border border-slate-800 bg-slate-900 p-4 transition-colors hover:bg-slate-800',
              f.hoverClass,
            ]}
          >
            <div class:list={['flex h-10 w-10 shrink-0 items-center justify-center rounded-lg text-xs font-bold', f.badgeClass]}>
              {f.initials}
            </div>
            <div class="flex-1 min-w-0">
              <p class="text-sm font-semibold text-white">{f.name}</p>
              <p class="text-xs text-slate-500">{f.sub}</p>
            </div>
            <svg class="h-4 w-4 shrink-0 text-slate-600 transition-colors group-hover:text-slate-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
            </svg>
          </a>
        ))}
      </div>

      <VCDirectory client:load firms={firms} />
    </main>

    <Footer />
  </div>

</Layout>
